<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0E2E"
    android:padding="24dp">

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_media_previous"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        app:tint="#9B7EC8" />

    <!-- Album art placeholder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:id="@+id/ivAlbumArt"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="#3D1F7A"
            android:src="@android:drawable/ic_media_play"/>

    </LinearLayout>

    <!-- Song info -->
    <TextView
        android:id="@+id/tvCurrentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Song Title"
        android:textColor="#F0E6C8"
        android:textSize="22sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tvCurrentArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Artist"
        android:textColor="#9B7EC8"
        android:textSize="15sp"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:progressTint="#C9A84C"
        android:thumbTint="#C9A84C"
        android:progressBackgroundTint="#3D1F7A"/>

    <!-- Time row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9B7EC8"
            android:textSize="12sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9B7EC8"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏮"
            android:textSize="20sp"
            android:textColor="#F0E6C8"
            android:backgroundTint="#3D1F7A"/>

        <Button
            android:id="@+id/btnPlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="▶"
            android:textSize="22sp"
            android:textColor="#1A0E2E"
            android:backgroundTint="#C9A84C"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏭"
            android:textSize="20sp"
            android:textColor="#F0E6C8"
            android:backgroundTint="#3D1F7A"/>

    </LinearLayout>

</LinearLayout>